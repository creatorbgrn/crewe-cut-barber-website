<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Dashboard | <%= business.name %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body class="admin-body">
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <p class="eyebrow">Admin</p>
        <h1><%= business.name %></h1>
        <p class="section-copy">Review booking requests, update statuses, and stay on top of incoming enquiries.</p>
        <form action="/admin/logout" method="post">
          <button class="button button-secondary button-full" type="submit">Log out</button>
        </form>
      </aside>

      <main class="admin-main">
        <section class="admin-meta-grid">
          <article class="stat-card">
            <strong><%= bookings.length %></strong>
            <span>Total bookings</span>
          </article>
          <article class="stat-card">
            <strong><%= bookings.filter((booking) => booking.status === 'new').length %></strong>
            <span>New requests</span>
          </article>
          <article class="stat-card">
            <strong><%= dbInfo.provider %></strong>
            <span>Database</span>
          </article>
          <article class="stat-card">
            <strong><%= bookings.filter((booking) => booking.status === 'confirmed').length %></strong>
            <span>Confirmed</span>
          </article>
          <article class="stat-card">
            <strong><%= bookings.filter((booking) => booking.status === 'contacted').length %></strong>
            <span>Contacted</span>
          </article>
          <article class="stat-card">
            <strong><%= bookings.filter((booking) => booking.status === 'completed').length %></strong>
            <span>Completed</span>
          </article>
        </section>

        <section class="admin-panel">
          <div class="section-head">
            <p class="eyebrow">Bookings</p>
            <h2>Incoming requests</h2>
          </div>
          <div class="mobile-bookings">
            <% bookings.forEach((booking) => { %>
              <article class="mobile-booking-card">
                <div class="mobile-booking-head">
                  <div>
                    <strong><%= booking.clientName %></strong>
                    <span><%= booking.createdAt %></span>
                  </div>
                  <span class="status-badge status-<%= booking.status %>"><%= booking.status %></span>
                </div>
                <dl class="mobile-booking-meta">
                  <div>
                    <dt>Service</dt>
                    <dd><%= booking.service %></dd>
                  </div>
                  <div>
                    <dt>Slot</dt>
                    <dd><%= booking.preferredDay %> at <%= booking.preferredTime %></dd>
                  </div>
                  <div>
                    <dt>Phone</dt>
                    <dd><a href="tel:<%= booking.phone.replace(/\s+/g, '') %>"><%= booking.phone %></a></dd>
                  </div>
                  <div>
                    <dt>Email</dt>
                    <dd><a href="mailto:<%= booking.email %>"><%= booking.email %></a></dd>
                  </div>
                  <div>
                    <dt>Notes</dt>
                    <dd><%= booking.notes || 'No notes provided.' %></dd>
                  </div>
                </dl>
                <form class="status-form" action="/admin/bookings/<%= booking.id %>/status" method="post">
                  <label>
                    Update status
                    <select name="status" onchange="this.form.submit()">
                      <% ['new', 'contacted', 'confirmed', 'completed'].forEach((status) => { %>
                        <option value="<%= status %>" <%= booking.status === status ? 'selected' : '' %>>
                          <%= status %>
                        </option>
                      <% }) %>
                    </select>
                  </label>
                </form>
              </article>
            <% }) %>
            <% if (!bookings.length) { %>
              <div class="mobile-booking-empty">No bookings yet.</div>
            <% } %>
          </div>
          <div class="table-wrap">
            <table class="bookings-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Service</th>
                  <th>Slot</th>
                  <th>Contact</th>
                  <th>Notes</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% bookings.forEach((booking) => { %>
                  <tr>
                    <td>
                      <strong><%= booking.clientName %></strong>
                      <span><%= booking.createdAt %></span>
                    </td>
                    <td><%= booking.service %></td>
                    <td><%= booking.preferredDay %><br><%= booking.preferredTime %></td>
                    <td>
                      <a href="tel:<%= booking.phone.replace(/\s+/g, '') %>"><%= booking.phone %></a><br>
                      <a href="mailto:<%= booking.email %>"><%= booking.email %></a>
                    </td>
                    <td><%= booking.notes || 'No notes provided.' %></td>
                    <td>
                      <form class="status-form" action="/admin/bookings/<%= booking.id %>/status" method="post">
                        <span class="status-badge status-<%= booking.status %>"><%= booking.status %></span>
                        <select name="status" onchange="this.form.submit()">
                          <% ['new', 'contacted', 'confirmed', 'completed'].forEach((status) => { %>
                            <option value="<%= status %>" <%= booking.status === status ? 'selected' : '' %>>
                              <%= status %>
                            </option>
                          <% }) %>
                        </select>
                      </form>
                    </td>
                  </tr>
                <% }) %>
                <% if (!bookings.length) { %>
                  <tr>
                    <td colspan="6">No bookings yet.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
